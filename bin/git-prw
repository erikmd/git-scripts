#!/usr/bin/env bash
set -euo pipefail
# Copyright (c) 2020-2021  Erik Martin-Dorel
#
# Licensed under the MIT license <https://opensource.org/licenses/MIT>
#
ts="Time-stamp: <2022-03-05 12:31:12 emartin>"; ts=${ts#Time-stamp: }

die_hard() {
    echo -e "$@" >&2
    exit 1
}

usage() {
    cat >&2 <<EOF
git-prw $ts

Facility to fetch a read/write branch from a GitHub repo Pull Request.

Usage:
  git prw [--ssh|--https] <ID> [<REMOTE>] [-f]

Example:
  git prw 390 upstream

Summary:
  If the REMOTE argument is omitted, it defaults to "origin".
  REMOTE must point to a GitHub repository.

  This command checks out the branch named "pr/ID". If it doesn't exist
  yet, it fetches the source branch for the PR #ID in the REMOTE repo
  and sets its upstream branch so that one can push to the PR branch.
  It reuses (if applicable) an existing remote
  matching that URL, or creates a remote named REMOTE-fork-for-pr-ID.
  The URL to use it picked for the same protocol as what REMOTE uses;
  passing --ssh or --https forces a specific protocol.

  Flag -f overwrites the local branch pr/ID even if it already exists.
  In general, it is a good idea to pass flag -f, unless we already ran
  "git pr ID REMOTE" and did commits in the local branch pr/ID.

  It requires curl <https://curl.se/> and (optionally) jq.

See also:
  - https://stackoverflow.com/a/62432946/9164010
  - https://help.github.com/en/github/collaborating-with-issues-and-pull-requests/checking-out-pull-requests-locally
  - https://help.github.com/en/github/collaborating-with-issues-and-pull-requests/allowing-changes-to-a-pull-request-branch-created-from-a-fork

Credits:
  The git-prw helper script was written by Erik Martin-Dorel and it is
  distributed under the MIT license <//opensource.org/licenses/MIT>.
EOF
}

get_remote_user_repo() {
    # ARG $1: "origin"
    # OUTPUT: "user/repo"
    #### OK for remote URLs:
    # git@github.com:user/repo.git
    # git@github.com:user/repo
    # https://github.com/user/repo.git
    # https://github.com/user/repo
    local remote=$1
    local url
    url=$(git remote get-url "$remote")
    url=${url##*github.com?}
    printf "%s" "${url%.git}"
}

get_pr_json() {
    # ARG $1: pull number
    # ARG $2: "origin"
    # OUTPUT: JSON <https://docs.github.com/en/rest/reference/pulls#list-pull-requests>
    local prid=$1
    local remote=$2
    local repo
    repo=$(get_remote_user_repo "$remote")
    if [[ $repo =~ ^[^/]+/[^/]+$ ]]; then
        curl -fsSH "Accept: application/vnd.github.v3+json" "https://api.github.com/repos/$repo/pulls/$prid"
    else
        die_hard "git-prw: Assert failed in get_pr_json(); incorrect CLI args?"
    fi
}

get_src_url_grep() {
    # ARG $1: JSON key, alphabetic
    local key=${1:?}
    grep -e '"'$key'"' | head -n1 | sed -e 's/^.*"'$key'":[[:space:]]*"//; s/",[[:space:]]*$//'
}

get_src_url_jq() {
    # ARG $1: JSON key, alphabetic
    local key=${1:?}
    jq -r '.head.repo.'$key
}

get_src_url() {
    # ARG $1: protocol
    # OUTPUT: Git URL
    local key
    
    case ${1:?} in
        ssh) key=ssh_url;;
        https) key=clone_url;;
        *) die_hard "unknown protocol: '$1'";;
    esac
    
    if command -v jq >/dev/null; then
        get_src_url_jq $key  # better
    else
        echo >&2 "Cannot find jq; fall back to grep/head/sed..."
        get_src_url_grep $key
    fi
}

get_src_ref_grep() {
    grep -e '"ref"' | head -n1 | sed -e 's/^.*"ref":[[:space:]]*"//; s/",[[:space:]]*$//'
}

get_src_ref_jq() {
    jq -r '.head.ref'
}

get_src_ref() {
    if command -v jq >/dev/null; then
        get_src_ref_jq  # better
    else
        echo >&2 "Cannot find jq; fall back to grep/head/sed..."
        get_src_ref_grep
    fi
}

get_new_remote_ifneedbe() {
    # ARG $1: remote_url
    # ARG $2: suggested_name, assumed to be unique
    # OUTPUT: name of a matching remote (an existing one, if possible)
    local remote_url=$1
    local unique_name=$2
    local push
    local remote
    push=$(git remote -v | grep -e "$remote_url .*push" | head -n1) || :
    if [ -n "$push" ]; then
        remote=$(cut -f 1 <<<"$push")
        printf >&2 "Using the remote:\\n  %s\\n" "$push"
        printf "%s" "$remote"
    else
        git remote remove "$unique_name" || :
        git remote add "$unique_name" "$remote_url"
        push=$(git remote -v | grep -e "$remote_url .*push" | head -n1)
        printf >&2 "Created the remote:\\n  %s\\n" "$push"
        printf "%s" "$unique_name"
    fi
}

already_exists() {
    # ARG $1: branch
    # RETURN: 0 if the branch exists
    branch="$1"
    git rev-parse --verify "$branch" >/dev/null 2>/dev/null
}

detect_protocol() {
    # ARG $1: remote URL
    # RETURN: ssh or https
    local remote=${1:?}
    local remote_url=$(git remote get-url "$remote")
    [[ $remote_url == "https://"* ]] && { echo "https"; return; }
    # https://stackoverflow.com/questions/31801271/what-are-the-supported-git-url-formats
    # How Git extracts username:password, see url_normalize in urlmatch.c . Laxer than RFC 3986
    [[ $remote_url == "ssh://"* || $remote_url =~ ^[^/?#@]+@.+ ]] && { echo "ssh"; return; }
    die_hard "cannot detect protocol for '$remote_url'"
}

main() {
    local prid
    local remote
    local json
    local protocol=
    local remote_url
    local unique_suggested_name
    local tracking_remote
    local ref
    local tracking_branch
    local force=false
    local args
    local k
    # Based on https://mywiki.wooledge.org/ComplexOptionParsing#util-linux.27s_special_getopt
    # Take advantage of util-linux `getopt's advanced parsing if available
    if getopt -T &>/dev/null && false || (( $? == 4 )) ; then
        eval set -- "$(getopt -o f -l ssh,https -- "$@")"
    else
        # Process optional CLI option -f, which can be anywhere
        args=("${@}")
        for (( k=0; k < $#; k++ )); do
            if [ "${args[$k]}" = "-f" ]; then
                force=true
                unset args["$k"]
            fi
        done
        set -- "${args[@]}"
    fi
    while (($# > 0)); do
        case $1 in
            --ssh) protocol="ssh";;
            --https) protocol="https";;
            -f) force=true;;
            --) shift; break;;
            *) break;;
        esac
        shift
    done
    
    if [ $# -lt 1 ]; then
        usage
        exit 0
    fi

    prid=$1
    remote=${2:-origin}
    
    if [[ -z $protocol ]]; then
        protocol=$(detect_protocol "$remote")
    fi

    if already_exists pr/"$prid" && [ "$force" = false ]; then
        echo >&2 "Preserving branch pr/$prid. To overwrite, use the -f flag."
    else
        echo >&2 "Overwriting branch pr/$prid..."
        git checkout -q "$(git rev-parse --verify HEAD)"
        git fetch -fv "$remote" pull/"$prid"/head:pr/"$prid"
    fi
    git checkout pr/"$prid"
    json=$(get_pr_json "$prid" "$remote")
    remote_url=$(get_src_url "$protocol" <<<"$json")
    ref=$(get_src_ref <<<"$json")
    unique_suggested_name="$remote-fork-for-pr-$prid"
    tracking_remote=$(get_new_remote_ifneedbe "$remote_url" "$unique_suggested_name")
    tracking_branch="$tracking_remote/$ref"
    git fetch "$tracking_remote" "$ref"
    git branch --set-upstream-to "$tracking_branch"
}

main "$@"
