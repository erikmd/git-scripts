# [ <-- needed because of Argbash


get_remote_user_repo() {
    # ARG $1: "origin"
    # OUTPUT: "user/repo"
    #### OK for remote URLs:
    # git@github.com:user/repo.git
    # git@github.com:user/repo
    # https://github.com/user/repo.git
    # https://github.com/user/repo
    local remote=$1
    local url
    url=$(git remote get-url "$remote")
    url=${url##*github.com?}
    printf "%s" "${url%.git}"
}

get_pr_json() {
    # ARG $1: pull number
    # ARG $2: "origin"
    # OUTPUT: JSON <https://docs.github.com/en/rest/reference/pulls#list-pull-requests>
    local prid=$1
    local remote=$2
    local repo
    repo=$(get_remote_user_repo "$remote")
    if [[ $repo =~ ^[^/]+/[^/]+$ ]]; then
        curl -fsSH "Accept: application/vnd.github.v3+json" "https://api.github.com/repos/$repo/pulls/$prid"
    else
        die "$0: Assert failed in get_pr_json(); incorrect CLI args?"
    fi
}

get_src_url_grep() {
    # ARG $1: JSON key, alphabetic
    local key=${1:?}
    grep -e '"'"$key"'"' | head -n1 | sed -e 's/^.*"'"$key"'":[[:space:]]*"//; s/",[[:space:]]*$//'
}

get_src_url_jq() {
    # ARG $1: JSON key, alphabetic
    local key=${1:?}
    jq -r ".head.repo.$key"
}

get_src_url() {
    # ARG $1: protocol
    # OUTPUT: Git URL
    local key

    case ${1:?} in
        ssh) key=ssh_url;;
        https) key=clone_url;;
        *) die "unknown protocol: '$1'";;
    esac

    if command -v jq >/dev/null; then
        get_src_url_jq "$key"  # better
    else
        echo >&2 "Cannot find jq; fall back to grep/head/sed..."
        get_src_url_grep "$key"
    fi
}

get_src_ref_grep() {
    grep -e '"ref"' | head -n1 | sed -e 's/^.*"ref":[[:space:]]*"//; s/",[[:space:]]*$//'
}

get_src_ref_jq() {
    jq -r '.head.ref'
}

get_src_ref() {
    if command -v jq >/dev/null; then
        get_src_ref_jq  # better
    else
        echo >&2 "Cannot find jq; fall back to grep/head/sed..."
        get_src_ref_grep
    fi
}

get_new_remote_ifneedbe() {
    # ARG $1: remote_url
    # ARG $2: suggested_name, assumed to be unique
    # OUTPUT: name of a matching remote (an existing one, if possible)
    local remote_url=$1
    local unique_name=$2
    local push
    local remote
    push=$(git remote -v | grep -e "$remote_url .*push" | head -n1) || :
    if [ -n "$push" ]; then
        remote=$(cut -f 1 <<<"$push")
        printf >&2 "Using the remote:\\n  %s\\n" "$push"
        printf "%s" "$remote"
    else
        git remote remove "$unique_name" || :
        git remote add "$unique_name" "$remote_url"
        push=$(git remote -v | grep -e "$remote_url .*push" | head -n1)
        printf >&2 "Created the remote:\\n  %s\\n" "$push"
        printf "%s" "$unique_name"
    fi
}

already_exists() {
    # ARG $1: branch
    # RETURN: 0 if the branch exists
    branch="$1"
    git rev-parse --verify "$branch" >/dev/null 2>/dev/null
}

detect_protocol() {
    # ARG $1: remote URL
    # RETURN: ssh or https
    local remote=${1:?}
    local remote_url
    remote_url=$(git remote get-url "$remote")
    [[ $remote_url == "https://"* ]] && { echo "https"; return; }
    # https://stackoverflow.com/questions/31801271/what-are-the-supported-git-url-formats
    # How Git extracts username:password, see url_normalize in urlmatch.c . Laxer than RFC 3986
    [[ $remote_url == "ssh://"* || $remote_url =~ ^[^/?#@]+@.+ ]] && { echo "ssh"; return; }
    die "cannot detect protocol for '$remote_url'"
}

main() {
    local remote="$_arg_remote"
    local prid="$_arg_prid"
    local protocol="$_arg_protocol"
    local force="$_arg_force"
    local remote_url
    local json
    local unique_suggested_name
    local tracking_remote
    local ref
    local tracking_branch
    local new_branch=pr/"$prid"
    local no_op=false
    local remote_already_set=false
    local no_changes=false


    if [[ -z $protocol ]]; then
        protocol=$(detect_protocol "$remote")
    fi

    json=$(get_pr_json "$prid" "$remote")
    remote_url=$(get_src_url "$protocol" <<<"$json")
    ref=$(get_src_ref <<<"$json")
    unique_suggested_name="$remote-fork-for-pr-$prid"
    tracking_remote=$(get_new_remote_ifneedbe "$remote_url" "$unique_suggested_name")
    tracking_branch="$tracking_remote/$ref"

    git fetch "$tracking_remote" "$ref"

    if already_exists "$new_branch"; then
        if [[ $force == "off" ]]; then
            [[ $(git rev-parse --abbrev-ref "$new_branch@{upstream}") == "$tracking_branch" ]] \
                    && remote_already_set=true
            [[ $(git rev-parse "$new_branch") == $(git rev-parse "$tracking_branch") ]] \
                    && no_changes=true
            if [[ $remote_already_set == "false" ]]; then
                die "A differently set up branch $new_branch already exists. To overwrite, use the -f flag."
            fi
            if [[ $no_changes == "true" ]]; then
                echo >&2 "Using existing branch $new_branch..."
            else
                echo >&2 "Using existing branch $new_branch. Use -f to reset it to upstream."
            fi
            no_op=true
        else
            echo >&2 "Overwriting branch $new_branch..."
        fi
    else
        echo >&2 "Creating branch $new_branch..."
    fi
    if [[ $no_op == "false" ]]; then
        git checkout -q "$(git rev-parse --verify HEAD)"
        git branch --track=direct --force "$new_branch" "$tracking_branch"
    fi
    git checkout "$new_branch"
}

main "$@"

