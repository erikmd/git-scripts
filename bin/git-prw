ts="Time-stamp: <2026-06-30 22:04:10 erik>"; ts=${ts#Time-stamp: }
description() {
cat <<EOF
Example:
  git prw 390 upstream

Summary:
  This command checks out the branch named "pr/\$prID". If it doesn't exist
  yet, it fetches the source branch for this PR in the REMOTE repo
  and sets its upstream branch so that one can push to the PR branch.
  It reuses (if applicable) an existing remote
  matching that URL, or creates a remote named REMOTE-fork-for-pr-\$prID.

  In general, it is a good idea to pass flag -f, unless we already ran
  "git pr prID REMOTE" and did commits in the local branch pr/ID.

  It requires curl <https://curl.se/> and (optionally) jq.

See also:
  - https://stackoverflow.com/a/62432946/9164010
  - https://help.github.com/en/github/collaborating-with-issues-and-pull-requests/checking-out-pull-requests-locally
  - https://help.github.com/en/github/collaborating-with-issues-and-pull-requests/allowing-changes-to-a-pull-request-branch-created-from-a-fork

Credits:
  The git-prw helper script was written by Erik Martin-Dorel and it is
  distributed under the MIT license <//opensource.org/licenses/MIT>.
EOF
}
#
# ARG_HELP([Facility to fetch a read/write branch from a GitHub repo Pull Request (PR).\n],[$(description)])
# ARG_VERSION([echo "git-prw $ts"])
# ARG_OPTIONAL_SINGLE([protocol],[p],[force using a specific protocol for the new remote.\nSupported values are 'ssh' and 'https'.\nBy default, the same protocol is used as in REMOTE])
# ARG_OPTIONAL_BOOLEAN([force],[f],[overwrite the branch if it exists])
# ARG_POSITIONAL_SINGLE([prID],[PR number],[])
# ARG_POSITIONAL_SINGLE([REMOTE],[GitHub remote that the PR targets],[origin])
# ARG_POSITIONAL_DOUBLEDASH([])
# ARG_DEFAULTS_POS([])
# ARGBASH_SET_INDENT([    ])
# ARGBASH_GO()
# needed because of Argbash --> m4_ignore([
